package application;

import java.util.Locale;
import java.util.Scanner;

public class Program03 {

	public static void main(String[] args) {
		Locale.setDefault(Locale.US);
		Scanner sc = new Scanner(System.in);
		
		System.out.print("Quantas pessoas serao digitadas? ");
		int n = sc.nextInt();
		
		String[] names = new String[n];
		int[] ages = new int[n];
		double[] heights = new double[n];

		// recebe os dados das pessoas
		for (int i = 0; i < n; i++) {
			System.out.println("Dados da " + (i+1) + "a pessoa:");
//			System.out.print("Nome: ");
//			names[i] = sc.next();
			System.out.print("Idade: ");
			ages[i] = sc.nextInt();
//			System.out.print("Altura: ");
//			heights[i] = sc.nextDouble();			
		}
		
		System.out.println();
		System.out.print("Altura media: ");
		double avg = 0;
		for (int i = 0; i < heights.length; i++) {
			avg += heights[i];
		}
		avg = avg / n;
		System.out.println(avg);
		
		System.out.println();
		System.out.println("Pessoas com menos de 16 anos: ");
		double agesUnder16 = 0.0;
		double agesOver16 = 0.0;
		for (int i = 0; i < ages.length; i++) {
			if (ages[i] < 16) {
				agesUnder16++;
			}
			else {
				agesOver16++;
			}
		}
		System.out.println("Under"+agesUnder16);
		System.out.println("Over"+agesOver16);
		
		agesUnder16 = (agesUnder16 / ages.length) * 100;
		System.out.print(agesUnder16 + "%");

	}

}
