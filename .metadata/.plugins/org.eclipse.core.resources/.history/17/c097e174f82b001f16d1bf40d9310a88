package application;

import java.util.Locale;
import java.util.Scanner;

/*
 * OBJETIVO: 
 * Digitar uma quantidade x de numeros reais,
 * armazena-los em um array,
 * imprimir o de maior valor e sua posicao no array*/

public class Program05 {

	public static void main(String[] args) {
		Locale.setDefault(Locale.US);
		Scanner sc = new Scanner(System.in);

		System.out.print("Quantos numeros voce vai digitar? ");
		int n = sc.nextInt();

		double[] vect = new double[n];

		// le e armazena os numeros no arranjo
		for (int i = 0; i < vect.length; i++) {
			System.out.print("Digite um numero: ");
			vect[i] = sc.nextDouble();
		}

		double highNum = 0;
		int position = 0;
		for (int i = 0; i < vect.length; i++) {
			if (vect[i] > highNum) {
				highNum = vect[i];
				position = i;
			}
		}

		System.out.println();
		System.out.print("MAIOR VALOR = " + highNum);
		System.out.println();
		System.out.print("POSICAO DO MAIOR VALOR = ");

		sc.close();
	}

}
